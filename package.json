{
  "name": "compile-draft",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "start": "node dist-server/src/server.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "nodemon --exec ts-node src/server.ts",
    "client": "vite",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "dev:host": "concurrently \"npm run server\" \"npm run client -- --host\""
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.100.10",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^1.11.0",
    "path": "^0.12.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "rsuite": "^6.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
